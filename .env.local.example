# /Users/parthkaran/Documents/claude_projects/liquidswap/.env.local.example

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/liquidswap

# Stellar Network
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Token Issuer (create at laboratory.stellar.org)
NEXT_PUBLIC_LQID_ISSUER=YOUR_ISSUER_PUBLIC_KEY
STELLAR_ISSUER_SECRET=YOUR_ISSUER_SECRET_KEY

# Liquidity Pool
NEXT_PUBLIC_POOL_ID=YOUR_POOL_ID_FROM_HORIZON
NEXT_PUBLIC_POOL_ADDRESS=YOUR_POOL_ESCROW_ADDRESS

# Admin
NEXT_PUBLIC_ADMIN_ADDRESS=YOUR_FREIGHTER_WALLET_ADDRESS
ADMIN_SECRET=your_random_admin_api_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
